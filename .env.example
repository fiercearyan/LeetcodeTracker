# ------------------------------------------------------------------
# MongoDB
# Local docker-compose default, or your MongoDB Atlas connection string
# ------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/leetcode-tracker

# ------------------------------------------------------------------
# NextAuth
# Generate a secret with: openssl rand -base64 32
# NEXTAUTH_URL should match your deployment URL (http://localhost:3000 in dev)
# ------------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------------
# Google OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
